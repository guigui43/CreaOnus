{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve Local",
            "type": "shell",
            "command": "npx",
            "args": ["serve", "-l", "3000"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.*)$",
                    "file": 1,
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "(Local:|Accepting connections at|localhost)"
                }
            }
        }
    ]
}
